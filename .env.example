# Copy this file to .env and fill in real values before running docker compose

# PostgreSQL password (used by both the db service and the backend)
DB_PASSWORD=change_me

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=change_me_base64_encoded_256bit_key

# Admin user created on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# CORS — set to your production domain (e.g. https://yourdomain.com)
CORS_ALLOWED_ORIGIN=http://localhost:4200